{
    "experiment_name": "c3_multidomain_experiments",
    "seed": 42,

    "model": {
        "name": "meta-llama/Llama-3.2-3B",
        "dtype": "bfloat16",
        "gradient_checkpointing": true
    },

    "lora": {
        "r": 16,
        "lora_alpha": 32,
        "target_modules": ["q_proj", "v_proj", "k_proj", "o_proj"],
        "lora_dropout": 0.05,
        "bias": "none",
        "task_type": "CAUSAL_LM"
    },

    "universal_teacher": {
        "clients": {
            "c1": {"dataset": "squad_v2",  "num_samples": 10000},
            "c2": {"dataset": "triviaqa",  "num_samples": 10000}
        },
        "aggregation": "ensemble"
    },

    "c3_domains": [
        {"name": "sciq",           "dataset": "sciq",           "train_samples": 50, "eval_samples": 150},
        {"name": "pubmedqa",       "dataset": "pubmedqa",       "train_samples": 50, "eval_samples": 150},
        {"name": "medqa",          "dataset": "medqa",          "train_samples": 50, "eval_samples": 150},
        {"name": "finqa",          "dataset": "finqa",          "train_samples": 50, "eval_samples": 150},
        {"name": "code_qa",        "dataset": "code_qa",        "train_samples": 50, "eval_samples": 150},
        {"name": "arc",            "dataset": "arc",            "train_samples": 50, "eval_samples": 150},
        {"name": "openbookqa",     "dataset": "openbookqa",     "train_samples": 50, "eval_samples": 150},
        {"name": "commonsense_qa", "dataset": "commonsense_qa", "train_samples": 50, "eval_samples": 150}
    ],

    "training": {
        "local_epochs": 3,
        "batch_size": 4,
        "gradient_accumulation_steps": 8,
        "learning_rate": 2e-4,
        "max_seq_length": 512
    },

    "knowledge_distillation": {
        "temperature": 2.0,
        "alpha": 0.5,
        "alpha_base": 0.25,
        "alpha_universal": 0.25
    },

    "evaluation": {
        "metrics": ["f1", "exact_match", "contains", "perplexity", "bertscore", "bleu", "rouge"],
        "eval_batch_size": 8
    },

    "logging": {
        "output_dir": "outputs",
        "checkpoint_every": 1
    }
}
